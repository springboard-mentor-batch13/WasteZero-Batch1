{
  "info": {
    "name": "WasteZero API",
    "description": "Smart Waste Pickup & Recycling Platform\n\nBase URL: http://localhost:3000/api/v1\n\nAuthentication: Bearer token (obtained from Login/Register)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET Health",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response has success true', () => pm.expect(pm.response.json().success).to.be.true);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Volunteer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "var json = pm.response.json();",
                  "pm.test('Has token', () => pm.expect(json.data.token).to.not.be.empty);",
                  "pm.environment.set('token', json.data.token);",
                  "pm.environment.set('userId', json.data.user.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"volunteer\",\n  \"skills\": [\"sorting\", \"driving\"],\n  \"location\": \"New York\",\n  \"bio\": \"Environment enthusiast\"\n}"
            },
            "url": "{{base_url}}/auth/register"
          }
        },
        {
          "name": "Register NGO",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "var json = pm.response.json();",
                  "pm.environment.set('ngoToken', json.data.token);",
                  "pm.environment.set('ngoId', json.data.user.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Green Earth NGO\",\n  \"email\": \"ngo@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"ngo\",\n  \"skills\": [\"management\", \"event planning\"],\n  \"location\": \"Mumbai\",\n  \"bio\": \"Environmental conservation organization\"\n}"
            },
            "url": "{{base_url}}/auth/register"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "var json = pm.response.json();",
                  "pm.environment.set('token', json.data.token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{base_url}}/auth/login"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get Profile",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has user data', () => pm.expect(pm.response.json().data.user).to.not.be.empty);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/users/profile"
          }
        },
        {
          "name": "Update Profile",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Updated\",\n  \"skills\": [\"sorting\", \"management\"],\n  \"location\": \"Boston\"\n}"
            },
            "url": "{{base_url}}/users/profile"
          }
        }
      ]
    },
    {
      "name": "Opportunities",
      "item": [
        {
          "name": "Create Opportunity",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "var json = pm.response.json();",
                  "pm.environment.set('opportunityId', json.data.opportunity._id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{ngoToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Beach Cleanup Drive\",\n  \"description\": \"Join us for a weekend beach cleanup event. Gloves and bags provided.\",\n  \"requiredSkills\": [\"cleaning\", \"teamwork\"],\n  \"location\": {\n    \"city\": \"Mumbai\",\n    \"state\": \"Maharashtra\"\n  },\n  \"duration\": {\n    \"value\": 4,\n    \"unit\": \"hours\"\n  },\n  \"maxVolunteers\": 20\n}"
            },
            "url": "{{base_url}}/opportunities"
          }
        },
        {
          "name": "Get All Opportunities",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has pagination', () => pm.expect(pm.response.json().data.pagination).to.not.be.empty);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/opportunities?page=1&limit=10&sort=newest",
              "host": ["{{base_url}}"],
              "path": ["opportunities"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "sort", "value": "newest" }
              ]
            }
          }
        },
        {
          "name": "Get Opportunity By ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/opportunities/{{opportunityId}}"
          }
        },
        {
          "name": "Update Opportunity",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{ngoToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Beach Cleanup Drive\",\n  \"maxVolunteers\": 30\n}"
            },
            "url": "{{base_url}}/opportunities/{{opportunityId}}"
          }
        },
        {
          "name": "Change Opportunity Status",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Status changed', () => pm.expect(pm.response.json().data.opportunity.status).to.eql('IN_PROGRESS'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{ngoToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"IN_PROGRESS\"\n}"
            },
            "url": "{{base_url}}/opportunities/{{opportunityId}}/status"
          }
        },
        {
          "name": "Delete Opportunity",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Soft deleted', () => pm.expect(pm.response.json().data.deletedAt).to.not.be.empty);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{ngoToken}}" }
            ],
            "url": "{{base_url}}/opportunities/{{opportunityId}}"
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000/api/v1",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "ngoToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "ngoId",
      "value": "",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "",
      "type": "string"
    },
    {
      "key": "opportunityId",
      "value": "",
      "type": "string"
    }
  ]
}
